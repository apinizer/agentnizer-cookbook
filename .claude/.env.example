# AI Pipeline — environment variables
# Copy this file to .claude/.env and edit if needed.
# All values are optional; the pipeline runs locally with no env config.

# ── Daemon configuration ───────────────────────────────────────────────
# How often the daemon polls .state/active.json (seconds)
LSD_POLL_INTERVAL=3

# How many tasks can run in parallel
LSD_MAX_PARALLEL_TASKS=3

# How many sub-agents per task can run in parallel (review fan-out)
LSD_MAX_PARALLEL_SUB=4

# Hard timeout per agent subprocess (seconds). Past this, the daemon
# SIGTERMs and then SIGKILLs the agent; the retry mechanism kicks in.
LSD_AGENT_TIMEOUT_SEC=900

# Daemon log file
LSD_LOG_FILE=~/.claude/logs/ai-pipeline-daemon.log

# Override paths (defaults resolved relative to repo root)
# PIPELINE_STATE_DIR=
# PIPELINE_AGENTS_DIR=
# PIPELINE_CLAUDE_BIN=claude

# ── Slack notifications (optional) ─────────────────────────────────────
# The pipeline uses Slack only for action-required events (security alerts,
# retry-limit failures, task FAILED). If you don't set these, the
# notify-slack hook prints to stderr and continues silently.
PIPELINE_SLACK_BOT_TOKEN=
PIPELINE_SLACK_CHANNEL=
